rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection (basic profile)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Generic pattern for branch-based collections
    function isTrainer() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer';
    }
    function userBranch() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branch;
    }

    match /notes/{docId} {
      allow read: if request.auth != null && (resource.data.branch == 'all' || userBranch() == resource.data.branch);
      allow create: if request.auth != null && isTrainer() && request.resource.data.uploadedBy == request.auth.uid && request.resource.data.branch is string;
      allow update: if request.auth != null && isTrainer() && resource.data.uploadedBy == request.auth.uid;
      allow delete: if false;
    }

    match /videos/{docId} {
      allow read: if request.auth != null && (resource.data.branch == 'all' || userBranch() == resource.data.branch);
      allow create: if request.auth != null && isTrainer() && request.resource.data.uploadedBy == request.auth.uid && request.resource.data.branch is string;
      allow update: if request.auth != null && isTrainer() && resource.data.uploadedBy == request.auth.uid;
      allow delete: if false;
    }

    match /links/{docId} {
      allow read: if request.auth != null && (resource.data.branch == 'all' || userBranch() == resource.data.branch);
      allow create: if request.auth != null && isTrainer() && request.resource.data.uploadedBy == request.auth.uid && request.resource.data.branch is string;
      allow update: if request.auth != null && isTrainer() && resource.data.uploadedBy == request.auth.uid;
      allow delete: if false;
    }

    match /tests/{docId} {
      allow read: if request.auth != null && (resource.data.branch == 'all' || userBranch() == resource.data.branch);
      allow create: if request.auth != null && isTrainer() && request.resource.data.createdBy == request.auth.uid && request.resource.data.branch is string;
      allow update: if request.auth != null && isTrainer() && resource.data.createdBy == request.auth.uid;
      allow delete: if false;
    }

    // Lectures collection (recorded lectures used by existing UI)
    match /lectures/{docId} {
      allow read: if request.auth != null && (resource.data.branch == 'all' || userBranch() == resource.data.branch);
      allow create: if request.auth != null && isTrainer() && request.resource.data.trainerId == request.auth.uid && request.resource.data.branch is string;
      allow update: if request.auth != null && isTrainer() && resource.data.trainerId == request.auth.uid;
      allow delete: if false;
    }

    // Notifications (trainers create, students read)
    match /notifications/{docId} {
      allow read: if request.auth != null && (resource.data.branch == 'all' || userBranch() == resource.data.branch);
      allow create: if request.auth != null && isTrainer();
    }

  }
}
